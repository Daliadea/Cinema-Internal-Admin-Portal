<%- include('../partials/header', { title: 'Booking Management' }) %>

<div class="container" id="main-content">
  <%- include('../partials/breadcrumb', { items: [{ label: 'Dashboard', href: '/dashboard' }, { label: 'Bookings' }] }) %>
  <div class="page-header">
    <div>
      <h1>Booking Management</h1>
      <p style="color: var(--light-text); font-size: 1rem; margin-top: 0.5rem;">All customer bookings from the CineVillage app</p>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="stats-grid" style="margin-bottom: 1.5rem;">
    <div class="stat-card success">
      <h3>Total Bookings</h3>
      <div class="stat-value"><%= bookings.length %></div>
      <p>Matching current filters</p>
    </div>
    <div class="stat-card info">
      <h3>Total Tickets</h3>
      <div class="stat-value"><%= totalTickets %></div>
      <p>Seats booked</p>
    </div>
    <div class="stat-card warning">
      <h3>Total Revenue</h3>
      <div class="stat-value">$<%= totalRevenue.toFixed(2) %></div>
      <p>From filtered bookings</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header"><h2 style="margin:0; font-size:1.1rem;">Filters</h2></div>
    <div class="card-body">
      <form method="GET" action="/admin/bookings" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; align-items: end;">
        <div>
          <label style="display:block; font-size:0.85rem; margin-bottom:0.35rem; color:var(--light-text);">Customer Email</label>
          <input type="text" name="email" value="<%= typeof filters !== 'undefined' && filters.email ? filters.email : '' %>" class="form-control" placeholder="Search email...">
        </div>
        <div>
          <label style="display:block; font-size:0.85rem; margin-bottom:0.35rem; color:var(--light-text);">Movie</label>
          <select name="movieId" class="form-control" style="width:100%; padding:0.5rem;">
            <option value="">All Movies</option>
            <% if (typeof movies !== 'undefined') { movies.forEach(m => { %>
              <option value="<%= m._id %>" <%= typeof filters !== 'undefined' && filters.movieId === m._id.toString() ? 'selected' : '' %>><%= m.title %></option>
            <% }); } %>
          </select>
        </div>
        <div>
          <label style="display:block; font-size:0.85rem; margin-bottom:0.35rem; color:var(--light-text);">Booked From</label>
          <input type="date" name="dateFrom" value="<%= typeof filters !== 'undefined' && filters.dateFrom ? filters.dateFrom : '' %>" class="form-control">
        </div>
        <div>
          <label style="display:block; font-size:0.85rem; margin-bottom:0.35rem; color:var(--light-text);">Booked To</label>
          <input type="date" name="dateTo" value="<%= typeof filters !== 'undefined' && filters.dateTo ? filters.dateTo : '' %>" class="form-control">
        </div>
        <div style="display:flex; gap:0.5rem;">
          <button type="submit" class="btn btn-primary">Apply</button>
          <a href="/admin/bookings" class="btn btn-secondary">Clear</a>
        </div>
      </form>
    </div>
  </div>

  <!-- Bookings Table -->
  <div class="card">
    <div class="card-header">
      <h2>All Bookings</h2>
      <span class="badge badge-info"><%= bookings.length %> records</span>
    </div>
    <div class="card-body" style="padding: 0;">
      <% if (bookings.length === 0) { %>
        <div class="empty-state" style="padding: 3rem;">
          <h3>No bookings found</h3>
          <p>No customer bookings match the current filters. Bookings will appear here once customers book via the CineVillage app.</p>
        </div>
      <% } else { %>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
            <thead>
              <tr style="background: var(--light-bg); border-bottom: 2px solid var(--border-color);">
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600; white-space: nowrap;">Ref</th>
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600;">Customer</th>
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600;">Movie</th>
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600; white-space: nowrap;">Screening Date</th>
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600;">Hall</th>
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600;">Seats</th>
                <th style="padding: 0.85rem 1rem; text-align: right; color: var(--light-text); font-weight: 600;">Amount</th>
                <th style="padding: 0.85rem 1rem; text-align: left; color: var(--light-text); font-weight: 600; white-space: nowrap;">Booked At</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach((booking, idx) => { %>
                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.15s;" onmouseover="this.style.background='var(--light-bg)'" onmouseout="this.style.background=''">
                  <td style="padding: 0.85rem 1rem;">
                    <span style="font-family: monospace; font-size: 0.85rem; background: var(--accent-color); color: white; padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600;"><%= booking.bookingRef %></span>
                  </td>
                  <td style="padding: 0.85rem 1rem;">
                    <div style="font-weight: 600; color: var(--dark-text);"><%= booking.customerName %></div>
                    <div style="font-size: 0.8rem; color: var(--light-text);"><%= booking.customerEmail %></div>
                  </td>
                  <td style="padding: 0.85rem 1rem;">
                    <% if (booking.screening && booking.screening.movie) { %>
                      <a href="/admin/movies/<%= booking.screening.movie._id %>" style="color: var(--accent-color); text-decoration: none; font-weight: 600;"><%= booking.screening.movie.title %></a>
                    <% } else { %>
                      <span class="text-muted">Deleted</span>
                    <% } %>
                  </td>
                  <td style="padding: 0.85rem 1rem; white-space: nowrap;">
                    <% if (booking.screening) { %>
                      <div style="font-weight: 600;"><%= new Date(booking.screening.startTime).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                      <div style="font-size: 0.8rem; color: var(--light-text);"><%= new Date(booking.screening.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></div>
                    <% } else { %>
                      <span class="text-muted">N/A</span>
                    <% } %>
                  </td>
                  <td style="padding: 0.85rem 1rem;">
                    <% if (booking.screening && booking.screening.hall) { %>
                      <%= booking.screening.hall.name %>
                    <% } else { %>
                      <span class="text-muted">N/A</span>
                    <% } %>
                  </td>
                  <td style="padding: 0.85rem 1rem;">
                    <div style="display: flex; flex-wrap: wrap; gap: 0.25rem;">
                      <% booking.seats.forEach(seat => { %>
                        <span style="background: var(--success-color); color: white; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.8rem; font-weight: 600; font-family: monospace;"><%= seat %></span>
                      <% }) %>
                    </div>
                  </td>
                  <td style="padding: 0.85rem 1rem; text-align: right; font-weight: 700; color: var(--success-color);">$<%= booking.totalAmount.toFixed(2) %></td>
                  <td style="padding: 0.85rem 1rem; white-space: nowrap; font-size: 0.85rem; color: var(--light-text);">
                    <%= new Date(booking.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
