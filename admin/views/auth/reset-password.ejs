<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - CineVillage Admin Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 fill=%22%231a1a2e%22/><text x=%2250%22 y=%2265%22 font-size=%2250%22 fill=%22%23e94560%22 text-anchor=%22middle%22 font-family=%22sans-serif%22>C</text></svg>">
  <script>
    (function(){const s=localStorage.getItem('darkMode');const d=window.matchMedia('(prefers-color-scheme: dark)').matches;
    if(s==='true'||(!s&&d))document.documentElement.classList.add('dark-mode');})();
  </script>
</head>
<body>
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <h1 class="gradient-text">CineVillage</h1>
        <p>Set a new password</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger">
          <span><%= error %></span>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success">
          <span><%= success %></span>
        </div>
        <div class="auth-links">
          <a href="/auth/login">← Go to Login</a>
        </div>
      <% } else if (token) { %>
        <form action="/auth/reset-password/<%= token %>" method="POST" id="resetForm">
          <div class="form-group">
            <label for="password">New Password</label>
            <input
              type="password"
              id="password"
              name="password"
              class="form-control"
              placeholder="Minimum 6 characters"
              required
              minlength="6"
              autofocus
            >
            <div class="password-strength" id="strengthBar" style="margin-top: 0.5rem; height: 4px; border-radius: 2px; background: #2a2a3e; overflow: hidden;">
              <div id="strengthFill" style="height: 100%; width: 0; transition: width 0.3s, background 0.3s;"></div>
            </div>
            <small id="strengthLabel" style="color: var(--text-muted); font-size: 0.75rem;"></small>
          </div>

          <div class="form-group">
            <label for="confirmPassword">Confirm New Password</label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              class="form-control"
              placeholder="Repeat your new password"
              required
            >
            <small id="matchLabel" style="font-size: 0.75rem;"></small>
          </div>

          <button type="submit" class="btn btn-primary" id="submitBtn" style="width: 100%; font-size: 1.05rem; padding: 1rem;">
            Reset Password
          </button>
        </form>

        <div class="auth-links" style="margin-top: 1.5rem;">
          <a href="/auth/login">← Back to Login</a>
        </div>
      <% } else { %>
        <div class="auth-links">
          <a href="/auth/forgot-password">← Request a new reset link</a>
        </div>
      <% } %>
    </div>
  </div>

  <% if (token) { %>
  <script>
    const passwordInput = document.getElementById('password');
    const confirmInput = document.getElementById('confirmPassword');
    const strengthFill = document.getElementById('strengthFill');
    const strengthLabel = document.getElementById('strengthLabel');
    const matchLabel = document.getElementById('matchLabel');

    // Show a simple weak / ok / strong label based on length
    passwordInput.addEventListener('input', function() {
      const len = this.value.length;
      let width, color, label;

      if (len === 0) {
        width = '0%'; color = '#2a2a3e'; label = '';
      } else if (len < 6) {
        width = '33%'; color = '#e94560'; label = 'Too short';
      } else if (len < 10) {
        width = '66%'; color = '#f5a623'; label = 'OK';
      } else {
        width = '100%'; color = '#4caf50'; label = 'Strong';
      }

      strengthFill.style.width = width;
      strengthFill.style.background = color;
      strengthLabel.textContent = label;
      checkMatch();
    });

    confirmInput.addEventListener('input', checkMatch);

    function checkMatch() {
      if (!confirmInput.value) { matchLabel.textContent = ''; return; }
      if (passwordInput.value === confirmInput.value) {
        matchLabel.textContent = 'Passwords match ✓';
        matchLabel.style.color = '#4caf50';
      } else {
        matchLabel.textContent = 'Passwords do not match';
        matchLabel.style.color = '#e94560';
      }
    }
  </script>
  <% } %>
</body>
</html>
